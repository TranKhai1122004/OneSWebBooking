@{
    ViewData["Title"] = "Trang chủ";
}

<div class="d-flex" style="min-height: 85vh;">

    <!-- KHỐI CHÍNH: logo và khung nút giờ ĐỘC LẬP với nhau -->
    <div class="flex-grow-1 position-relative bg-white" style="min-height: 85vh;">

        <!-- Logo oneS: ghim sát trái, dịch xuống 1 chút để mép trên chữ "SMARTCARD SYSTEM" ngang hàng mép trên khung nút -->
        <div class="position-absolute" style="left: 30px; top: 110px;">
            <h1 class="display-4 fw-bold text-danger m-0" style="font-family: 'Arial Black', sans-serif;">one<span class="text-primary">S</span></h1>
            <div class="badge bg-primary text-wrap fw-bold px-3 py-2 mt-1" style="font-size: 11px; letter-spacing: 1px;">
                oneS SMARTCARD SYSTEM
            </div>
        </div>

        <!-- Bảng 8 nút: vẫn tự căn giữa toàn bộ khối chính, không bị ảnh hưởng bởi logo -->
        <div class="d-flex align-items-center justify-content-center h-100" style="min-height: 85vh;">
            <div class="p-4 border rounded shadow-sm" style="background-color: #d6d6d6; width: 620px;">
                <div class="row g-3">
                    <div class="col-6">
                        <button class="btn btn-light w-100 py-3 text-start border shadow-sm fw-bold d-flex align-items-center">
                            <i class="fas fa-cash-register text-warning fs-4 me-3"></i> Bán dịch vụ (F5)
                        </button>
                    </div>
                    <div class="col-6">
                        <button class="btn btn-light w-100 py-3 text-start border shadow-sm fw-bold d-flex align-items-center">
                            <i class="fas fa-search text-success fs-4 me-3"></i> Tìm kiếm hóa đơn (F10)
                        </button>
                    </div>
                    <div class="col-6">
                        <button class="btn btn-light w-100 py-3 text-start border shadow-sm fw-bold d-flex align-items-center">
                            <i class="fas fa-undo text-primary fs-4 me-3"></i> Hoàn dịch vụ (F7)
                        </button>
                    </div>
                    <div class="col-6">
                        <button class="btn btn-light w-100 py-3 text-start border shadow-sm fw-bold d-flex align-items-center">
                            <i class="fas fa-hand-holding-usd text-success fs-4 me-3"></i> Nạp tiền (F11)
                        </button>
                    </div>
                    <div class="col-6">
                        <button class="btn btn-light w-100 py-3 text-start border shadow-sm fw-bold d-flex align-items-center">
                            <i class="fas fa-user-check text-info fs-4 me-3"></i> Tra cứu tài khoản
                        </button>
                    </div>
                    <div class="col-6">
                        <button class="btn btn-light w-100 py-3 text-start border shadow-sm fw-bold d-flex align-items-center">
                            <i class="fas fa-print text-secondary fs-4 me-3"></i> Bán dịch vụ bên trong khu
                        </button>
                    </div>
                    <div class="col-6">
                        <button class="btn btn-light w-100 py-3 text-start border shadow-sm fw-bold d-flex align-items-center">
                            <i class="fas fa-id-card-alt text-success fs-4 me-3"></i> Checkin sử dụng dịch vụ (F3)
                        </button>
                    </div>
                    <div class="col-6">
                        <button class="btn btn-light w-100 py-3 text-start border shadow-sm fw-bold d-flex align-items-center">
                            <i class="fas fa-key text-danger fs-4 me-3"></i> Kết thúc ca
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- CỘT PHẢI: giữ nguyên như lần trước -->
    <div class="bg-light border-start p-3 d-flex flex-column justify-content-between" style="width: 200px; flex-shrink: 0;">
        <div>
            <div class="mb-4">
                <label class="form-label fw-bold text-muted small">Site hiện hành:</label>
                <select class="form-select form-select-sm border-primary fw-bold">
                    <option selected>Núi Thần Tài</option>
                    <option>Vinpearl land Phú Quốc</option>
                    <option>Cổng chính C1</option>
                </select>
            </div>
            <div class="border-top pt-3">
                <h6 class="fw-bold text-center text-primary border-bottom pb-2">== Núi Thần Tài ==</h6>
                <div class="card bg-white border-0 shadow-sm mt-3">
                    <div class="card-body" style="font-size: 12px; line-height: 1.6;">
                        <p class="mb-2"><strong>Thông tin hỗ trợ liên hệ theo thứ tự sau:</strong></p>
                        <ol class="ps-3 mb-3">
                            <li>Lỗi máy tính/mạng: <strong class="text-danger">IT Dept</strong></li>
                            <li>
                                Hỗ trợ phần mềm SmartCard:
                                <ul class="ps-3 mt-1 text-muted">
                                    <li>Hotline: Mr. Lương 0869991139</li>
                                    <li>Email: <span>luongdv</span>&#64;<span>dhcgroup.vn</span></li>
                                </ul>
                            </li>
                        </ol>
                    </div>
                </div>
            </div>
        </div>
        <div class="text-center text-muted small border-top pt-3">
            <span>oneS Client Service Engine v2.0</span>
        </div>
    </div>
</div>