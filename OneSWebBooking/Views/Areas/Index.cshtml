@model IEnumerable<OneSWebBooking.Models.Area>

@{
    ViewData["Title"] = "Khai báo khu vực";
}

<style>
    body {
        background-color: #f0f0f0;
        font-family: Arial, sans-serif;
    }
    /* Khung giả lập cửa sổ Windows App */
    .winform-window {
        background-color: #f0f0f0;
        border: 1px solid #999;
        box-shadow: 2px 2px 10px rgba(0,0,0,0.2);
        font-size: 13px;
    }

    .winform-toolbar {
        background-color: #e1e1e1;
        border-bottom: 1px solid #b5b5b5;
        padding: 6px 10px;
    }

    .winform-btn {
        background: none;
        border: 1px solid transparent;
        padding: 5px 12px;
        font-size: 12px;
        color: #000;
        cursor: pointer;
        border-radius: 3px;
        display: inline-flex;
        flex-direction: column;
        align-items: center;
        min-width: 60px;
    }

        .winform-btn:hover:not(:disabled) {
            background-color: #cce4f7;
            border-color: #a8d2f0;
        }

        .winform-btn:disabled {
            color: #888 !important;
            cursor: not-allowed;
        }

        .winform-btn i {
            font-size: 18px;
            margin-bottom: 3px;
        }

    .winform-groupbox {
        border: 1px solid #d0d0d0;
        padding: 15px;
        margin: 10px;
        position: relative;
        background-color: #f0f0f0;
    }

    .winform-groupbox-title {
        position: absolute;
        top: -10px;
        left: 15px;
        background-color: #f0f0f0;
        padding: 0 5px;
        font-weight: bold;
        color: #333;
    }
    /* Ô nhập liệu mờ đi khi bị khóa ở chế độ readonly */
    .form-control-sm[readonly] {
        background-color: #e9ecef;
        color: #6c757d;
        border-color: #ced4da;
    }

    .winform-grid-container {
        margin: 10px;
        border: 1px solid #bcbcbc;
        background-color: #fff;
        height: 320px;
        overflow-y: auto;
    }

    .winform-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

        .winform-table th {
            background-color: #f0f0f0;
            border-right: 1px solid #d0d0d0;
            border-bottom: 2px solid #b5b5b5;
            padding: 6px 8px;
            text-align: left;
            position: sticky;
            top: 0;
            z-index: 10;
        }

        .winform-table td {
            border-right: 1px solid #e0e0e0;
            border-bottom: 1px solid #e0e0e0;
            padding: 6px 8px;
            cursor: pointer;
        }

        .winform-table tr:hover {
            background-color: #f5f5f5;
        }

        .winform-table tr.selected-row {
            background-color: #3399ff !important;
            color: #fff !important;
        }

    .winform-statusbar {
        background-color: #f0f0f0;
        border-top: 1px solid #b5b5b5;
        padding: 4px 10px;
        font-size: 12px;
        color: #444;
        display: flex;
        justify-content: space-between;
    }

    .statusbar-item {
        border-right: 1px solid #ccc;
        padding-right: 15px;
        margin-right: 15px;
    }

        .statusbar-item:last-child {
            border-right: none;
        }
</style>

<div class="container-fluid mt-3">
    <div class="card winform-window">
        <!-- FORM CHỨA THÔNG TIN ĐỂ GỬI LÊN CONTROLLER -->
        <form id="areaForm" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" id="areaId" name="Id" />

            <!-- 1. THANH CÔNG CỤ NÚT BẤM (TOOLBAR) -->
            <div class="winform-toolbar d-flex justify-content-between align-items-center">
                <div class="d-flex gap-1">
                    <button type="button" id="btnCreate" class="winform-btn text-success">
                        <i class="fas fa-plus-circle"></i>Thêm mới
                    </button>
                    <button type="button" id="btnEdit" class="winform-btn text-warning" disabled>
                        <i class="fas fa-edit"></i>Sửa
                    </button>
                    <button type="button" id="btnDelete" class="winform-btn text-danger" disabled>
                        <i class="fas fa-times-circle"></i>Xóa
                    </button>

                    <!-- Nút Ghi và Hủy mặc định ẩn đi, chỉ hiện khi đang gõ Thêm/Sửa -->
                    <button type="button" id="btnSave" class="winform-btn text-primary d-none">
                        <i class="fas fa-save"></i>Ghi
                    </button>
                    <button type="button" id="btnCancel" class="winform-btn text-secondary d-none">
                        <i class="fas fa-undo"></i>Hủy
                    </button>
                </div>
                <div>
                    <a href="/" class="winform-btn text-dark text-decoration-none">
                        <i class="fas fa-power-off"></i>Thoát
                    </a>
                </div>
            </div>

            <!-- 2. KHUNG NHẬP THÔNG TIN (FIELDS) -->
            <div class="winform-groupbox">
                <div class="winform-groupbox-title">Thông tin</div>
                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="d-flex align-items-center">
                            <label class="me-2 text-nowrap" style="width: 50px;">Tên</label>
                            <input type="text" id="areaName" name="AreaName" class="form-control form-control-sm border-secondary rounded-0" readonly required />
                        </div>
                        <span class="text-danger small ms-5 d-block" id="errorAreaName"></span>
                    </div>
                    <div class="col-md-5">
                        <div class="d-flex align-items-center">
                            <label class="me-2 text-nowrap" style="width: 50px;">Mô tả</label>
                            <input type="text" id="description" name="Description" class="form-control form-control-sm border-secondary rounded-0" readonly />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="d-flex align-items-center">
                            <label class="me-2 text-nowrap" style="width: 70px;">Trạng thái</label>
                            <select id="status" name="Status" class="form-select form-select-sm border-secondary rounded-0" style="pointer-events: none; background-color: #e9ecef;">
                                <option value="true">đang hoạt động</option>
                                <option value="false">không sử dụng</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>
        </form>

        <!-- 3. BẢNG HIỂN THỊ DANH SÁCH KHU VỰC -->
        <div class="winform-grid-container">
            <table class="winform-table" id="gridTable">
                <thead>
                    <tr>
                        <th style="width: 30%">Tên</th>
                        <th style="width: 45%">Mô tả</th>
                        <th style="width: 25%">Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr data-id="@item.Id"
                            data-name="@item.AreaName"
                            data-desc="@item.Description"
                            data-status="@item.Status.ToString().ToLower()"
                            data-createdby="@item.CreatedBy"
                            data-createddate="@(item.CreatedDate?.ToString("dd/MM/yyyy HH:mm:ss") ?? "...")"
                            data-modifiedby="@item.ModifiedBy"
                            data-modifieddate="@(item.ModifiedDate?.ToString("dd/MM/yyyy HH:mm:ss") ?? "...")">
                            <td class="fw-bold">@item.AreaName</td>
                            <td>@item.Description</td>
                            <td>@(item.Status ? "đang hoạt động" : "không sử dụng")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- 4. THANH TRẠNG THÁI CHÂN TRANG (AUDIT LOGS) -->
        <div class="winform-statusbar">
            <div class="d-flex">
                <div class="statusbar-item">Người tạo: <span id="lblCreatedBy" class="text-primary fw-bold">...</span></div>
                <div class="statusbar-item">Ngày tạo: <span id="lblCreatedDate" class="text-dark">...</span></div>
                <div class="statusbar-item">Người sửa: <span id="lblModifiedBy" class="text-primary fw-bold">...</span></div>
                <div class="statusbar-item">Ngày sửa: <span id="lblModifiedDate" class="text-dark">...</span></div>
            </div>
            <div>
                <span>Tổng số bản ghi: <strong>@Model.Count()</strong></span>
            </div>
        </div>
    </div>
</div>

<!-- POPUP THÔNG BÁO LỖI -->
<div class="modal fade" id="alertModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content rounded-0 border-dark">
            <div class="modal-header bg-danger text-white py-1 px-2 rounded-0">
                <span class="fw-bold small"><i class="fas fa-exclamation-triangle"></i> Thông báo lỗi</span>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close" style="font-size: 10px;"></button>
            </div>
            <div class="modal-body text-center py-3 px-2" id="alertModalMessage" style="font-size: 13px;"></div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            let currentAction = ""; // Trạng thái: rỗng, "create", hoặc "edit"

            // 1. CLICK CHỌN 1 DÒNG TRÊN BẢNG GRID
            $("#gridTable tbody tr").click(function () {
                if (currentAction !== "") return; // Đang thêm/sửa thì khóa bảng

                $("#gridTable tbody tr").removeClass("selected-row");
                $(this).addClass("selected-row");

                // Đổ ngược dữ liệu lên các ô nhập thông tin phía trên
                $("#areaId").val($(this).data("id"));
                $("#areaName").val($(this).data("name"));
                $("#description").val($(this).data("desc"));
                $("#status").val($(this).data("status"));

                // Đổ thông tin Audit Log xuống chân trang
                $("#lblCreatedBy").text($(this).data("createdby") || "...");
                $("#lblCreatedDate").text($(this).data("createddate") || "...");
                $("#lblModifiedBy").text($(this).data("modifiedby") || "...");
                $("#lblModifiedDate").text($(this).data("modifieddate") || "...");

                // Sáng nút Sửa và Xóa
                $("#btnEdit").prop("disabled", false);
                $("#btnDelete").prop("disabled", false);
            });

            // 2. BẤM NÚT THÊM MỚI
            $("#btnCreate").click(function () {
                currentAction = "create";
                clearFields();
                enableInputs(true);

                // Ẩn các nút nghiệp vụ cũ, hiện Ghi và Hủy
                $("#btnCreate, #btnEdit, #btnDelete").addClass("d-none");
                $("#btnSave, #btnCancel").removeClass("d-none");
            });

            // 3. BẤM NÚT SỬA
            $("#btnEdit").click(function () {
                currentAction = "edit";
                enableInputs(true);

                // Ẩn các nút nghiệp vụ cũ, hiện Ghi và Hủy
                $("#btnCreate, #btnEdit, #btnDelete").addClass("d-none");
                $("#btnSave, #btnCancel").removeClass("d-none");
            });

            // 4. BẤM NÚT HỦY (QUAY LẠI TRẠNG THÁI BAN ĐẦU)
            $("#btnCancel").click(function () {
                currentAction = "";
                enableInputs(false);
                clearFields();
                $("#gridTable tbody tr").removeClass("selected-row");

                // Khôi phục lại thanh công cụ
                $("#btnCreate, #btnEdit, #btnDelete").removeClass("d-none");
                $("#btnSave, #btnCancel").addClass("d-none");
                $("#btnEdit, #btnDelete").prop("disabled", true);
            });

            // 5. BẤM NÚT GHI (GỌI AJAX ĐẾN CONTROLLER ĐỂ LƯU)
            $("#btnSave").click(function () {
                let name = $("#areaName").val().trim();
                if (name === "") {
                    $("#errorAreaName").text("Vui lòng nhập tên khu vực!");
                    return;
                }
                $("#errorAreaName").text("");

                // Gửi form đi một cách chính thống (input dùng readonly nên serialize lấy dữ liệu hoàn hảo)
                let url = currentAction === "create" ? "/Areas/Create" : `/Areas/Edit/${$("#areaId").val()}`;
                let formData = $("#areaForm").serialize();

                $.post(url, formData)
                    .done(function () {
                        window.location.reload();
                    })
                    .fail(function (xhr) {
                        // Hiển thị câu báo lỗi thực tế từ Backend gửi về
                        let errorMsg = xhr.responseText || "Tên khu vực này đã tồn tại hoặc dữ liệu không hợp lệ!";
                        showError(errorMsg);
                    });
            });

            // 6. BẤM NÚT XÓA
            $("#btnDelete").click(function () {
                let id = $("#areaId").val();
                if (!id) return;

                if (confirm("Bạn có chắc chắn muốn xóa khu vực đang chọn không?")) {
                    let token = $('input[name="__RequestVerificationToken"]').val();
                    $.post(`/Areas/Delete/${id}`, { id: id, __RequestVerificationToken: token })
                        .done(function () {
                            window.location.reload();
                        })
                        .fail(function () {
                            showError("Không thể xóa khu vực này vì đang có máy tính hoạt động tại đây!");
                        });
                }
            });

            // HÀM BỔ TRỢ ĐÓNG/MỞ KHÓA Ô NHẬP LIỆU
            function enableInputs(enable) {
                if (enable) {
                    $("#areaName, #description").removeAttr("readonly");
                    $("#status").css({"pointer-events": "auto", "background-color": "#fff"});
                    $("#areaName").focus();
                } else {
                    $("#areaName, #description").attr("readonly", "readonly");
                    $("#status").css({"pointer-events": "none", "background-color": "#e9ecef"});
                }
            }

            // HÀM XÓA TRẮNG DỮ LIỆU TRÊN CÁC Ô NHẬP
            function clearFields() {
                $("#areaId, #areaName, #description").val("");
                $("#status").val("true");
                $("#lblCreatedBy, #lblCreatedDate, #lblModifiedBy, #lblModifiedDate").text("...");
            }

            // HÀM BẬT POPUP THÔNG BÁO LỖI
            function showError(msg) {
                $("#alertModalMessage").text(msg);
                new bootstrap.Modal(document.getElementById('alertModal')).show();
            }
        });
    </script>
}